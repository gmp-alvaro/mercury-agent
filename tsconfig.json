{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@mercury-agent/types": ["packages/types/src/index.ts"],
      "@mercury-agent/mercury": ["packages/mercury/src/index.ts"],
      "@mercury-agent/agent": ["packages/agent/src/index.ts"]
    }
  }
}
